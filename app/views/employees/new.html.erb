<div class="dashboard">

  <div class="sidebar">

    <h2>Employee Management</h2>

    <ul>
      <li><%= link_to "Employees", employees_path %></li>

      <li>
        <%= button_to "Logout",
        logout_path,
        method: :delete %>
      </li>
    </ul>

  </div>

  <div class="content">

    <div class="form-card">

      <h1>Add Employee</h1>

      <%= form_with model:@employee do |form| %>

        <div class="form-group">
          <%= form.label :name %>
          <%= form.text_field :name %>
        </div>

        <div class="form-group">
          <%= form.label :email %>
          <%= form.email_field :email %>
        </div>

        <div class="form-group">
          <%= form.label :department %>
          <%= form.text_field :department %>
        </div>

        <div class="form-group">
          <%= form.label :salary %>
          <%= form.number_field :salary %>
        </div>

        <%= form.submit "Save Employee",
        class:"save-btn" %>

      <% end %>

    </div>

  </div>

</div>