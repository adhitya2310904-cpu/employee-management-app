<div class="dashboard">

  <div class="sidebar">

    <div class="sidebar-top">

      <h2>Employee Management</h2>

      <ul>

        <li>
          <%= link_to "Dashboard", employees_path %>
        </li>

        <li class="active-link">
          <%= link_to "Add Employee", new_employee_path %>
        </li>

      </ul>

    </div>

    <div class="logout-section">

      <%= link_to "Logout",
          destroy_user_session_path,
          data: { turbo_method: :delete },
          class: "logout-link" %>

    </div>

  </div>

  <div class="content">

    <div class="top-bar">
      Welcome, <%= current_user.email %>
    </div>

    <div class="form-card">

      <h1>Add Employee</h1>

      <p class="subtitle">
        Fill the details to add a new employee
      </p>

      <%= form_with model: @employee do |form| %>

        <div class="form-group">
          <%= form.label :name %>
          <%= form.text_field :name,
              placeholder: "Enter employee name" %>
        </div>

        <div class="form-group">
          <%= form.label :email %>
          <%= form.email_field :email,
              placeholder: "Enter employee email" %>
        </div>

        <div class="form-group">
          <%= form.label :department %>
          <%= form.text_field :department,
              placeholder: "Enter department" %>
        </div>

        <div class="form-group">
          <%= form.label :salary %>
          <%= form.number_field :salary,
              placeholder: "Enter salary" %>
        </div>

        <div class="field">
  <%= form.label :profile_picture %>
  <%= form.file_field :profile_picture %>
</div>

        <div class="button-group">

          <%= form.submit "Save Employee",
              class: "save-btn" %>

          <%= link_to "Cancel",
              employees_path,
              class: "cancel-btn" %>

        </div>

      <% end %>

    </div>

  </div>

</div>