<div class="dashboard">

  <div class="sidebar">

    <div class="sidebar-top">

      <h2>Employee Management</h2>

      <ul>
        <li>
          <%= link_to "Dashboard", employees_path %>
        </li>

        <li class="active-link">
          <%= link_to "Edit Employee",
              edit_employee_path(@employee) %>
        </li>
      </ul>

    </div>

    <div class="logout-section">

      <%= link_to "Logout",
          destroy_user_session_path,
          data: { turbo_method: :delete },
          class: "logout-link" %>

    </div>

  </div>

  <div class="content">

    <div class="top-bar">
      Welcome, <%= current_user.email %>
    </div>

    <div class="form-card">

      <h1>Edit Employee</h1>

      <%= form_with model: @employee do |form| %>

        <div class="form-group">

          <%= form.label :name %>

          <%= form.text_field :name %>

        </div>

        <div class="form-group">

          <%= form.label :email %>

          <%= form.email_field :email %>

        </div>

        <div class="form-group">

          <%= form.label :department %>

          <%= form.text_field :department %>

        </div>

        <div class="form-group">

          <%= form.label :salary %>

          <%= form.number_field :salary %>

        </div>

        <div class="button-group">

          <%= form.submit "Update Employee",
              class: "save-btn" %>

          <%= link_to "Cancel",
              employees_path,
              class: "cancel-btn" %>

        </div>

      <% end %>

    </div>

  </div>

</div>