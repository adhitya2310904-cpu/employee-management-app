<div class="content">

  <div class="page-card">

    <h1>Apply Leave</h1>

    <p class="page-subtitle">
      Submit a leave request for approval
    </p>

    <%= form_with model: @leave_request,
                  local: true do |f| %>

      <div class="form-group">

        <%= f.label :employee_id, "Employee" %>

        <%= f.collection_select :employee_id,
                                Employee.all,
                                :id,
                                :name,
                                {},
                                class: "form-control" %>

      </div>

      <div class="form-group">

        <%= f.label :leave_type %>

        <%= f.select :leave_type,
                     [
                       "Casual Leave",
                       "Sick Leave",
                       "Earned Leave",
                       "Emergency Leave"
                     ],
                     {},
                     class: "form-control" %>

      </div>

      <div class="form-group">

        <%= f.label :start_date %>

        <%= f.date_field :start_date,
                         class: "form-control" %>

      </div>

      <div class="form-group">

        <%= f.label :end_date %>

        <%= f.date_field :end_date,
                         class: "form-control" %>

      </div>

      <div class="form-group">

        <%= f.label :reason %>

        <%= f.text_area :reason,
                        class: "form-control textarea" %>

      </div>

      <div class="form-group">

        <%= f.label :medical_document,
                    "Medical Document (Optional)" %>

        <%= f.file_field :medical_document,
                         class: "form-control" %>

      </div>

      <div class="button-group">

        <%= f.submit "Apply Leave",
                     class: "save-btn" %>

        <%= link_to "Cancel",
                    leave_requests_path,
                    class: "cancel-btn" %>

      </div>

    <% end %>

  </div>

</div>